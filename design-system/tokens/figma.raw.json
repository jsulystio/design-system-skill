        "color/text/on-accent": { "type": "COLOR", "values": { "Light": "{primitives.color.white}",    "Dark": "{primitives.color.gray.900}" } },
        "color/border/default": { "type": "COLOR", "values": { "Light": "{primitives.color.gray.200}", "Dark": "{primitives.color.gray.800}" } },
